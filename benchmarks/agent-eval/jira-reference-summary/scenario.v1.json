{
  "schema_version": 1,
  "id": "jira.synthetic-reference-summary",
  "category": "surface-native",
  "task_class": "jira/evidence",
  "description": "Read one Jira issue through its reconciled reference summaries and report exact per-kind, source-provenance, deduplication, and consistency facts.",
  "data_class": "synthetic",
  "required_capabilities": ["jira.issue.refs"],
  "required_checks": [
    "atl_succeeded",
    "complete_correct",
    "guard_clean",
    "http_exact",
    "issues_correct",
    "mock_clean",
    "no_delegation",
    "selection_correct",
    "summary_correct",
    "truncated_correct",
    "used_atl",
    "used_atl_twice",
    "used_skill"
  ],
  "required_semantic_checks": [
    "complete_correct",
    "issues_correct",
    "selection_correct",
    "summary_correct",
    "truncated_correct"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "atl_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis",
    "capability_families"
  ],
  "budgets": {
    "max_agent_turns": 8,
    "max_tool_calls": 4,
    "max_atl_invocations": 2,
    "max_delegations": 0,
    "max_backend_requests": 2,
    "max_duplicate_backend_requests": 0,
    "max_remote_writes": 0,
    "max_output_bytes": 32768,
    "max_input_tokens": 180000,
    "max_output_tokens": 6000,
    "max_main_thread_input_tokens": 180000,
    "max_main_thread_output_tokens": 6000,
    "max_estimated_cost_microusd": 5000000,
    "max_duration_millis": 300000,
    "allowed_http_methods": ["GET"]
  }
}
