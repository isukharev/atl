{
  "schema_version": 1,
  "id": "confluence.synthetic-table-analytics-mcp-v3",
  "category": "surface-native",
  "task_class": "confluence/table-analytics",
  "description": "Derive one bounded analytical result from exactly one typed selected-table MCP read while preserving row, merged-value, identifier, filter, aggregate, and untrusted-data semantics.",
  "data_class": "synthetic",
  "required_capabilities": ["confluence.table.extract"],
  "required_checks": [
    "bounded_interface",
    "count_correct",
    "count_semantics_correct",
    "embedded_content_safe",
    "formula_safety_correct",
    "formula_values_correct",
    "guard_clean",
    "http_exact",
    "interface_succeeded",
    "items_correct",
    "mock_clean",
    "multiline_correct",
    "no_delegation",
    "qualifying_ids_correct",
    "selected_table_correct",
    "total_correct",
    "used_interface"
  ],
  "required_semantic_checks": [
    "count_correct",
    "count_semantics_correct",
    "embedded_content_safe",
    "formula_safety_correct",
    "formula_values_correct",
    "items_correct",
    "multiline_correct",
    "qualifying_ids_correct",
    "selected_table_correct",
    "total_correct"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "interface_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis",
    "capability_families"
  ],
  "budgets": {
    "max_agent_turns": 4,
    "max_tool_calls": 1,
    "max_atl_invocations": 0,
    "max_interface_invocations": 1,
    "max_delegations": 0,
    "max_backend_requests": 1,
    "max_duplicate_backend_requests": 0,
    "max_remote_writes": 0,
    "max_output_bytes": 98304,
    "max_input_tokens": 220000,
    "max_output_tokens": 8000,
    "max_main_thread_input_tokens": 220000,
    "max_main_thread_output_tokens": 8000,
    "max_estimated_cost_microusd": 10000000,
    "max_duration_millis": 300000,
    "allowed_http_methods": ["GET"]
  }
}
