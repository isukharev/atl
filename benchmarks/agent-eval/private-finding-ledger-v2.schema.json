{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isukharev/atl/benchmarks/agent-eval/private-finding-ledger-v2.schema.json",
  "title": "ATL private agent-evaluation finding ledger v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "failure",
        "failure_class",
        "product_issues",
        "decision"
      ],
      "properties": {
        "finding_id": {
          "$ref": "#/$defs/id"
        },
        "failure": {
          "$ref": "#/$defs/evidenceRef"
        },
        "failure_class": {
          "enum": [
            "model",
            "contract-preflight",
            "transport-vpn",
            "backend-drift",
            "unsupported-capability",
            "safety",
            "qualitative",
            "harness"
          ]
        },
        "product_issues": {
          "$ref": "#/$defs/publicIDs"
        },
        "pull_requests": {
          "$ref": "#/$defs/publicIDs"
        },
        "changed_contracts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "$ref": "#/$defs/contractTransition"
          }
        },
        "regression": {
          "$ref": "#/$defs/evidenceRef"
        },
        "decision": {
          "enum": ["fixed", "accepted", "unsupported", "deferred", "investigate"]
        }
      },
      "dependentRequired": {
        "pull_requests": ["changed_contracts"],
        "changed_contracts": ["pull_requests"]
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "failure": {
                  "$ref": "#/$defs/privateLiveRef"
                },
                "regression": {
                  "$ref": "#/$defs/privateLiveRef"
                }
              }
            },
            {
              "properties": {
                "failure": {
                  "$ref": "#/$defs/syntheticRootRef"
                },
                "regression": {
                  "$ref": "#/$defs/syntheticRootRef"
                }
              }
            }
          ]
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "fixed"
              }
            },
            "required": ["decision"]
          },
          "then": {
            "required": ["pull_requests", "changed_contracts", "regression"]
          }
        }
      ]
    },
    "evidenceRef": {
      "oneOf": [
        {
          "$ref": "#/$defs/privateLiveRef"
        },
        {
          "$ref": "#/$defs/syntheticRootRef"
        }
      ]
    },
    "privateLiveRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "plan_id", "surface", "baseline"],
      "properties": {
        "source": {
          "const": "private-live"
        },
        "plan_id": {
          "type": "string",
          "pattern": "^pln-[0-9a-f]{32}$"
        },
        "surface": {
          "enum": ["cli-skill", "atl-mcp", "external-mcp"]
        },
        "baseline": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,63}$",
          "not": {
            "const": "current"
          }
        }
      }
    },
    "syntheticRootRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "assessment_sha256"],
      "properties": {
        "source": {
          "const": "synthetic-root"
        },
        "assessment_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "contractTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "before_sha256", "after_sha256"],
      "properties": {
        "kind": {
          "enum": [
            "plan-contract",
            "prompt-contract",
            "task-contract",
            "execution-contract",
            "atl-executable",
            "skill-digest"
          ]
        },
        "before_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "after_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "publicIDs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "uniqueItems": true,
      "items": {
        "type": "integer",
        "minimum": 1
      }
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
