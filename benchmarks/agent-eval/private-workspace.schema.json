{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isukharev/atl/benchmarks/agent-eval/private-workspace.schema.json",
  "title": "ATL private agent-evaluation workspace manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "live_config_env",
    "execution",
    "retention",
    "run_sets"
  ],
  "properties": {
    "schema_version": {
      "const": 3
    },
    "live_config_env": {
      "$ref": "#/$defs/environmentName"
    },
    "external_mcp_profile_env": {
      "$ref": "#/$defs/environmentName"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_estimated_cost_microusd"
      ],
      "properties": {
        "max_estimated_cost_microusd": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000000
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keep_completed_run_sets_per_alias",
        "max_candidate_age_days",
        "max_candidate_bytes",
        "retain_baseline_transcripts"
      ],
      "properties": {
        "keep_completed_run_sets_per_alias": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "max_candidate_age_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "max_candidate_bytes": {
          "type": "integer",
          "minimum": 1048576,
          "maximum": 1099511627776
        },
        "retain_baseline_transcripts": {
          "type": "boolean"
        }
      }
    },
    "run_sets": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "alias",
          "spec_paths",
          "qualitative_review_required"
        ],
        "properties": {
          "kind": {
            "enum": [
              "comparison",
              "activation-study"
            ]
          },
          "alias": {
            "$ref": "#/$defs/alias"
          },
          "spec_paths": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 512,
              "allOf": [
                {
                  "pattern": "^cases/[^\\r\\n\\u0000\\\\]+\\.json$"
                },
                {
                  "not": {
                    "pattern": "(^|/)(\\.|\\.\\.)(/|$)|//"
                  }
                }
              ]
            }
          },
          "qualitative_review_required": {
            "type": "boolean"
          },
          "reviewer_reserve_microusd": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100000000
          },
          "calibration_max_estimated_cost_microusd": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100000000
          },
          "qualitative_review_panel": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "method",
              "reviewers",
              "max_criterion_range_bps"
            ],
            "properties": {
              "method": {
                "const": "criterion-median-v1"
              },
              "reviewers": {
                "type": "array",
                "description": "Reviewer ids must be unique; doctor enforces id uniqueness in addition to JSON item uniqueness.",
                "uniqueItems": true,
                "items": {
                  "$ref": "#/$defs/reviewer"
                },
                "oneOf": [
                  {
                    "minItems": 3,
                    "maxItems": 3
                  },
                  {
                    "minItems": 5,
                    "maxItems": 5
                  }
                ]
              },
              "max_criterion_range_bps": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9999
              },
              "blind_assignment": {
                "$ref": "#/$defs/caseFilePath"
              }
            }
          }
        },
        "allOf": [
          {
            "not": {
              "required": [
                "qualitative_review_panel"
              ],
              "properties": {
                "qualitative_review_required": {
                  "const": true
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "activation-study"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "required": [
                "qualitative_review_panel",
                "reviewer_reserve_microusd",
                "calibration_max_estimated_cost_microusd"
              ],
              "properties": {
                "spec_paths": {
                  "minItems": 4,
                  "maxItems": 4
                },
                "qualitative_review_required": {
                  "const": false
                },
                "qualitative_review_panel": {
                  "required": [
                    "blind_assignment"
                  ]
                }
              }
            },
            "else": {
              "properties": {
                "spec_paths": {
                  "maxItems": 3
                }
              },
              "not": {
                "anyOf": [
                  {"required": ["reviewer_reserve_microusd"]},
                  {"required": ["calibration_max_estimated_cost_microusd"]}
                ]
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "alias": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "environmentName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
    },
    "caseFilePath": {
      "type": "string",
      "maxLength": 512,
      "allOf": [
        {
          "pattern": "^cases/[^\\r\\n\\u0000\\\\]*[^/\\r\\n\\u0000\\\\]$"
        },
        {
          "not": {
            "pattern": "(^|/)(\\.|\\.\\.)(/|$)|//"
          }
        }
      ]
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "enum": [
            "human",
            "codex",
            "claude-code"
          ]
        },
        "model": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^[^\\r\\n\\u0000]*$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "codex",
                  "claude-code"
                ]
              }
            }
          },
          "then": {
            "required": [
              "model"
            ],
            "properties": {
              "model": {
                "type": "string",
                "minLength": 1,
                "pattern": ".*\\S.*"
              }
            }
          }
        }
      ]
    }
  }
}
