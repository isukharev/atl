{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isukharev/atl/benchmarks/agent-eval/private-workspace.schema.json",
  "title": "ATL private agent-evaluation workspace manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "live_config_env",
    "execution",
    "retention",
    "run_sets"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "live_config_env": {
      "$ref": "#/$defs/environmentName"
    },
    "external_mcp_profile_env": {
      "$ref": "#/$defs/environmentName"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_estimated_cost_microusd"
      ],
      "properties": {
        "max_estimated_cost_microusd": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000000
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keep_completed_run_sets_per_alias",
        "max_candidate_age_days",
        "max_candidate_bytes",
        "retain_baseline_transcripts"
      ],
      "properties": {
        "keep_completed_run_sets_per_alias": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "max_candidate_age_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365
        },
        "max_candidate_bytes": {
          "type": "integer",
          "minimum": 1048576,
          "maximum": 1099511627776
        },
        "retain_baseline_transcripts": {
          "type": "boolean"
        }
      }
    },
    "run_sets": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "alias",
          "spec_paths",
          "qualitative_review_required"
        ],
        "properties": {
          "alias": {
            "$ref": "#/$defs/alias"
          },
          "spec_paths": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "maxLength": 512,
              "allOf": [
                {
                  "pattern": "^cases/[^\\r\\n\\u0000\\\\]+\\.json$"
                },
                {
                  "not": {
                    "pattern": "(^|/)(\\.|\\.\\.)(/|$)|//"
                  }
                }
              ]
            }
          },
          "qualitative_review_required": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "$defs": {
    "alias": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "environmentName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
    }
  }
}
