{
  "schema_version": 1,
  "id": "jira.synthetic-portfolio-source-discovery",
  "category": "surface-native",
  "task_class": "jira/portfolio",
  "description": "Discover a filtered Agile board and stable Structure folders before selecting a bounded portfolio source.",
  "data_class": "synthetic",
  "required_capabilities": ["jira.board.list", "jira.structure.folders"],
  "required_checks": [
    "atl_succeeded",
    "boards_correct",
    "folders_correct",
    "guard_clean",
    "http_exact",
    "mock_clean",
    "no_delegation",
    "structure_correct",
    "used_atl",
    "used_atl_three_times",
    "used_skill"
  ],
  "required_semantic_checks": [
    "boards_correct",
    "folders_correct",
    "structure_correct"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "atl_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis",
    "capability_families"
  ],
  "budgets": {
    "max_agent_turns": 10,
    "max_tool_calls": 6,
    "max_atl_invocations": 3,
    "max_delegations": 0,
    "max_backend_requests": 4,
    "max_duplicate_backend_requests": 0,
    "max_remote_writes": 0,
    "max_output_bytes": 32768,
    "max_input_tokens": 220000,
    "max_output_tokens": 8000,
    "max_main_thread_input_tokens": 220000,
    "max_main_thread_output_tokens": 8000,
    "max_estimated_cost_microusd": 5000000,
    "max_duration_millis": 300000,
    "allowed_http_methods": ["GET", "POST"]
  }
}
