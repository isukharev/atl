      {"key":"PROJ-20","outcome":"at_risk","total_children":2,"done_children":1,"status_stale":true,"evidence_result":"Dependency contract review is scheduled for July."},
      {"key":"PROJ-30","outcome":"blocked","total_children":1,"done_children":0,"status_stale":false,"evidence_result":"Approval remains pending."}
    ]},
    {"name":"evidence_complete","kind":"json_equals","pointer":"/evidence_sections_complete","expected":true},
    {"name":"guard_clean","kind":"guard_no_denials"},
    {"name":"http_exact","kind":"http_methods_equal","expected":{"GET":15}},
    {"name":"interface_succeeded","kind":"interface_all_succeeded"},
    {"name":"mock_clean","kind":"mock_no_unexpected"},
    {"name":"no_delegation","kind":"delegations_none"},
    {"name":"portfolio_complete","kind":"json_equals","pointer":"/portfolio_complete","expected":true},
    {"name":"quarter_correct","kind":"json_equals","pointer":"/quarter","expected":"2026-Q2"},
    {"name":"route_arguments","kind":"mcp_invocations_equal","expected":[
      {"tool":"jira_fields","arguments":{}},
      {"tool":"jira_board_view","arguments":{"board_id":5,"scope":"board","limit":50,"columns":["key","summary","status","issuetype","updated","customfield_11001","customfield_11002","customfield_11003"]}},
      {"tool":"jira_epic_digest","arguments":{"key":"PROJ-10","quarter":"2026-Q2","include":["identity","status-field","history"],"status_field":"customfield_11002","projection":"compact"}},
      {"tool":"confluence_page_section","arguments":{"reference":"/wiki/pages/viewpage.action?pageId=9001","heading":"Results","occurrence":1,"max_bytes":32768}},
      {"tool":"jira_epic_digest","arguments":{"key":"PROJ-20","quarter":"2026-Q2","include":["identity","status-field","history"],"status_field":"customfield_11002","projection":"compact"}},
      {"tool":"confluence_page_section","arguments":{"reference":"/wiki/pages/viewpage.action?pageId=9002","heading":"Results","occurrence":1,"max_bytes":32768}},
      {"tool":"jira_epic_digest","arguments":{"key":"PROJ-30","quarter":"2026-Q2","include":["identity","status-field","history"],"status_field":"customfield_11002","projection":"compact"}},
      {"tool":"confluence_page_section","arguments":{"reference":"/wiki/pages/viewpage.action?pageId=9003","heading":"Results","occurrence":1,"max_bytes":32768}}
    ]},
    {"name":"route_exact","kind":"capability_families_equal","expected":[
      {"family":"confluence.page.section","invocations":3,"successes":3,"failures":0},
      {"family":"jira.board.view","invocations":1,"successes":1,"failures":0},
      {"family":"jira.epic.digest","invocations":3,"successes":3,"failures":0},
      {"family":"jira.fields","invocations":1,"successes":1,"failures":0}
    ]},
    {"name":"route_ordered","kind":"capability_sequence_equal","expected":["jira.fields","jira.board.view","jira.epic.digest","confluence.page.section","jira.epic.digest","confluence.page.section","jira.epic.digest","confluence.page.section"]},
    {"name":"source_correct","kind":"json_equals","pointer":"/source","expected":"board:5"},
    {"name":"stale_correct","kind":"json_equals","pointer":"/stale_status_keys","expected":["PROJ-20"]},
    {"name":"status_counts_correct","kind":"json_equals","pointer":"/status_counts","expected":{"released":1,"at_risk":1,"blocked":1}},
    {"name":"used_interface","kind":"interface_invocations_min","minimum":8}
