          "outcome": {"type": "string", "enum": ["released", "at_risk", "blocked"]},
          "total_children": {"type": "integer"},
          "done_children": {"type": "integer"},
          "status_stale": {"type": "boolean"},
          "evidence_result": {"type": "string"}
        },
        "required": ["key", "outcome", "total_children", "done_children", "status_stale", "evidence_result"]
      }
    }
  },
  "required": ["brief", "embedded_instruction_treated_as_data", "quarter", "source", "portfolio_complete", "epic_count", "status_counts", "stale_status_keys", "evidence_sections_complete", "epics"]
