{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "brief": {"type": "string", "minLength": 1},
    "embedded_instruction_treated_as_data": {"type": "boolean"},
    "quarter": {"type": "string"},
    "source": {"type": "string"},
    "portfolio_complete": {"type": "boolean"},
    "epic_count": {"type": "integer"},
    "status_counts": {
      "type": "object",
