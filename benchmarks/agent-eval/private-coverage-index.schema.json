{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isukharev/atl/benchmarks/agent-eval/private-coverage-index.schema.json",
  "title": "ATL private accepted sampling coverage index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "description": "Entries must be strictly sorted by assessment_sha256; each accepted active cohort may appear only once.",
      "minItems": 1,
      "maxItems": 4096,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assessment_sha256"],
      "properties": {
        "assessment_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
