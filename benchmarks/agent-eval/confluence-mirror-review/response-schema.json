    "byte_only_changes": {"type": "array", "items": {"type": "string"}},
    "unchanged": {"type": "array", "items": {"type": "string"}},
    "blocked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "page": {"type": "string"},
          "state": {"type": "string", "enum": ["baseline_mismatch"]},
          "action": {"type": "string", "enum": ["preserve-and-repair-baseline"]}
