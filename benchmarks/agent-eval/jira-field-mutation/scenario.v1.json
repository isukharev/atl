{
  "schema_version": 1,
  "id": "jira.synthetic-guarded-field-mutation",
  "task_class": "jira/edit",
  "description": "Exercise the preview, reviewed apply, and ambiguous-outcome boundaries of one file-backed Jira custom-field mutation.",
  "data_class": "synthetic",
  "required_capabilities": ["jira.issue.field.preview", "jira.issue.field.set"],
  "required_checks": [
    "atl_outcome_expected",
    "expected_updated_correct",
    "field_correct",
    "guard_clean",
    "http_exact",
    "issue_key_correct",
    "mock_clean",
    "next_action_correct",
    "outcome_correct",
    "proposal_hash_correct",
    "replayed_false",
    "used_atl",
    "used_skill",
    "write_attempted_correct"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "atl_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis"
  ],
  "budgets": {
    "max_agent_turns": 12,
    "max_tool_calls": 12,
    "max_atl_invocations": 2,
    "max_delegations": 0,
    "max_backend_requests": 6,
    "max_duplicate_backend_requests": 3,
    "max_remote_writes": 1,
    "max_output_bytes": 32768,
    "max_input_tokens": 500000,
    "max_output_tokens": 20000,
    "max_main_thread_input_tokens": 500000,
    "max_main_thread_output_tokens": 20000,
    "max_estimated_cost_microusd": 10000000,
    "max_duration_millis": 600000,
    "allowed_http_methods": ["GET", "PUT"]
  }
}
