{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isukharev/atl/benchmarks/agent-eval/private-sampling.schema.json",
  "title": "ATL private sampling evidence specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tier", "primary"],
  "properties": {
    "schema_version": {"const": 1},
    "tier": {"enum": ["calibration", "regression", "decision"]},
    "primary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/run_ref"}
    },
    "holdout": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/run_ref"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"tier": {"const": "calibration"}}, "required": ["tier"]},
      "then": {"properties": {"primary": {"minItems": 1, "maxItems": 1}, "holdout": {"maxItems": 0}}}
    },
    {
      "if": {"properties": {"tier": {"const": "regression"}}, "required": ["tier"]},
      "then": {
        "required": ["holdout"],
        "properties": {"primary": {"minItems": 3, "maxItems": 3}, "holdout": {"minItems": 1}}
      }
    },
    {
      "if": {"properties": {"tier": {"const": "decision"}}, "required": ["tier"]},
      "then": {
        "required": ["holdout"],
        "properties": {"primary": {"minItems": 10}, "holdout": {"minItems": 1}}
      }
    }
  ],
  "$defs": {
    "run_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_id", "surface", "baseline"],
      "properties": {
        "plan_id": {"type": "string", "pattern": "^pln-[0-9a-f]{32}$"},
        "surface": {"enum": ["cli-skill", "atl-mcp", "external-mcp"]},
        "baseline": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$", "not": {"const": "current"}}
      }
    }
  }
}
