{
  "schema_version": 1,
  "id": "jira.synthetic-ordered-batch-read",
  "category": "neutral-common",
  "task_class": "jira/batch-analysis",
  "description": "Read a known Jira selector set once, preserve first-occurrence identity order, distinguish duplicates from a missing identity, and summarize the complete returned rows.",
  "data_class": "synthetic",
  "required_capabilities": [
    "jira.batch.issue.export"
  ],
  "required_checks": [
    "all_requested_found_correct",
    "backend_complete",
    "bounded_interface",
    "duplicates_correct",
    "embedded_content_safe",
    "found_rows_correct",
    "guard_clean",
    "interface_succeeded",
    "missing_correct",
    "mock_clean",
    "no_delegation",
    "original_order_correct",
    "unique_order_correct",
    "used_interface"
  ],
  "required_semantic_checks": [
    "all_requested_found_correct",
    "backend_complete",
    "duplicates_correct",
    "embedded_content_safe",
    "found_rows_correct",
    "missing_correct",
    "original_order_correct",
    "unique_order_correct"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "interface_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis",
    "capability_families"
  ],
  "budgets": {
    "max_agent_turns": 8,
    "max_tool_calls": 8,
    "max_atl_invocations": 0,
    "max_interface_invocations": 3,
    "max_delegations": 0,
    "max_backend_requests": 2,
    "max_duplicate_backend_requests": 0,
    "max_remote_writes": 0,
    "max_output_bytes": 16384,
    "max_input_tokens": 250000,
    "max_output_tokens": 8000,
    "max_main_thread_input_tokens": 250000,
    "max_main_thread_output_tokens": 8000,
    "max_estimated_cost_microusd": 10000000,
    "max_duration_millis": 600000,
    "allowed_http_methods": [
      "GET"
    ]
  }
}
