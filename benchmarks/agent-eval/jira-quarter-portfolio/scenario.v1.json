{
  "schema_version": 1,
  "id": "jira.synthetic-quarter-portfolio",
  "task_class": "jira/portfolio",
  "description": "Build a qualified quarterly result from one portfolio snapshot, narrow epic history, and bounded linked Confluence evidence.",
  "data_class": "synthetic",
  "required_capabilities": [
    "jira.board.view",
    "jira.portfolio.epic.digest",
    "jira.portfolio.confluence.section"
  ],
  "required_checks": [
    "atl_succeeded",
    "epics_correct",
    "evidence_complete",
    "guard_clean",
    "mock_clean",
    "portfolio_complete",
    "quarter_correct",
    "source_correct",
    "stale_correct",
    "used_atl"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "atl_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis"
  ],
  "budgets": {
    "max_agent_turns": 32,
    "max_tool_calls": 32,
    "max_atl_invocations": 12,
    "max_delegations": 1,
    "max_backend_requests": 20,
    "max_duplicate_backend_requests": 4,
    "max_remote_writes": 0,
    "max_output_bytes": 131072,
    "max_input_tokens": 750000,
    "max_output_tokens": 30000,
    "max_main_thread_input_tokens": 750000,
    "max_main_thread_output_tokens": 30000,
    "max_estimated_cost_microusd": 10000000,
    "max_duration_millis": 600000,
    "allowed_http_methods": ["GET"]
  }
}
