      {"key":"PROJ-10","outcome":"released","total_children":2,"done_children":2,"status_stale":false,"evidence_result":"Pilot adoption reached 42 percent."},
      {"key":"PROJ-20","outcome":"at_risk","total_children":2,"done_children":1,"status_stale":true,"evidence_result":"Dependency contract review is scheduled for July."},
      {"key":"PROJ-30","outcome":"blocked","total_children":1,"done_children":0,"status_stale":false,"evidence_result":"Approval remains pending."}
    ]},
    {"name": "evidence_complete", "kind": "json_equals", "pointer": "/evidence_sections_complete", "expected": true},
    {"name": "guard_clean", "kind": "guard_no_denials"},
    {"name": "mock_clean", "kind": "mock_no_unexpected"},
    {"name": "no_delegation", "kind": "delegations_none"},
    {"name": "portfolio_complete", "kind": "json_equals", "pointer": "/portfolio_complete", "expected": true},
    {"name": "quarter_correct", "kind": "json_equals", "pointer": "/quarter", "expected": "2026-Q2"},
    {"name": "source_correct", "kind": "json_equals", "pointer": "/source", "expected": "board:5"},
    {"name": "stale_correct", "kind": "json_equals", "pointer": "/stale_status_keys", "expected": ["PROJ-20"]},
    {"name": "status_counts_correct", "kind": "json_equals", "pointer": "/status_counts", "expected": {"released":1,"at_risk":1,"blocked":1}},
    {"name": "used_atl", "kind": "atl_invocations_min", "minimum": 1}
  ]
}
