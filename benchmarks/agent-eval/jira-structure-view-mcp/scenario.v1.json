  "required_semantic_checks": [
    "accessibility_correct",
    "complete_correct",
    "content_not_mutated",
    "counts_correct",
    "embedded_content_safe",
    "hierarchy_correct",
    "projection_correct",
    "selection_correct",
    "structure_correct"
  ],
  "required_metrics": [
