{
  "schema_version": 1,
  "id": "confluence.synthetic-page-evidence-v2",
  "category": "surface-native",
  "task_class": "confluence/evidence",
  "description": "Resolve one Confluence page, inspect repeated headings, and read only the current approved section through the bounded typed interface.",
  "data_class": "synthetic",
  "required_capabilities": [
    "confluence.page.resolve",
    "confluence.page.outline",
    "confluence.page.section"
  ],
  "required_checks": [
    "bounded_interface",
    "brief_present",
    "complete_correct",
    "decision_correct",
    "embedded_content_safe",
    "guard_clean",
    "heading_correct",
    "http_exact",
    "interface_succeeded",
    "limit_correct",
    "mock_clean",
    "no_delegation",
    "occurrence_correct",
    "owner_correct",
    "page_correct",
    "used_interface"
  ],
  "required_semantic_checks": [
    "brief_present",
    "complete_correct",
    "decision_correct",
    "embedded_content_safe",
    "heading_correct",
    "limit_correct",
    "occurrence_correct",
    "owner_correct",
    "page_correct"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "interface_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis",
    "capability_families"
  ],
  "budgets": {
    "max_agent_turns": 6,
    "max_tool_calls": 4,
    "max_atl_invocations": 0,
    "max_interface_invocations": 3,
    "max_delegations": 0,
    "max_backend_requests": 2,
    "max_duplicate_backend_requests": 1,
    "max_remote_writes": 0,
    "max_output_bytes": 32768,
    "max_input_tokens": 160000,
    "max_output_tokens": 5000,
    "max_main_thread_input_tokens": 160000,
    "max_main_thread_output_tokens": 5000,
    "max_estimated_cost_microusd": 5000000,
    "max_duration_millis": 300000,
    "allowed_http_methods": ["GET"]
  }
}
