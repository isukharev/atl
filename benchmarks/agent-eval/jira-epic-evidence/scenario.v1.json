{
  "schema_version": 1,
  "id": "jira.synthetic-epic-evidence",
  "task_class": "jira/evidence",
  "description": "Discover an unfamiliar custom field and collect qualified epic evidence through the shipped agent workflow.",
  "data_class": "synthetic",
  "required_capabilities": [
    "jira.issue.fields",
    "jira.epic.digest"
  ],
  "required_checks": [
    "atl_succeeded",
    "child_count_correct",
    "issue_key_correct",
    "mock_clean",
    "sources_complete",
    "status_description_correct",
    "summary_correct",
    "used_atl"
  ],
  "required_metrics": [
    "agent_turns",
    "tool_calls",
    "atl_invocations",
    "delegations",
    "backend_requests",
    "duplicate_backend_requests",
    "output_bytes",
    "input_tokens",
    "output_tokens",
    "main_thread_input_tokens",
    "main_thread_output_tokens",
    "estimated_cost_microusd",
    "duration_millis"
  ],
  "budgets": {
    "max_agent_turns": 12,
    "max_tool_calls": 12,
    "max_atl_invocations": 4,
    "max_delegations": 0,
    "max_backend_requests": 15,
    "max_duplicate_backend_requests": 6,
    "max_remote_writes": 0,
    "max_output_bytes": 32768,
    "max_input_tokens": 500000,
    "max_output_tokens": 20000,
    "max_main_thread_input_tokens": 500000,
    "max_main_thread_output_tokens": 20000,
    "max_estimated_cost_microusd": 10000000,
    "max_duration_millis": 600000,
    "allowed_http_methods": [
      "GET"
    ]
  }
}
