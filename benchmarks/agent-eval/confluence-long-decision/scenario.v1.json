  "required_semantic_checks": ["bounded_context", "brief_present", "complete", "decision_correct", "embedded_content_safe", "limit_correct", "occurrence_correct", "owner_correct", "page_correct", "rollback_correct", "strategy_correct"],
  "required_metrics": ["agent_turns", "tool_calls", "interface_invocations", "delegations", "backend_requests", "duplicate_backend_requests", "output_bytes", "input_tokens", "output_tokens", "main_thread_input_tokens", "main_thread_output_tokens", "estimated_cost_microusd", "duration_millis"],
