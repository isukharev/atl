      "pointer": "/selected_table",
      "expected": 2
    },
    {
      "name": "total_correct",
      "kind": "json_equals",
      "pointer": "/forecast_total",
      "expected": 450
    },
    {
      "name": "used_interface",
      "kind": "interface_invocations_min",
      "minimum": 1
    },
    {
      "name": "used_skill",
      "kind": "skill_invocations_min",
      "minimum": 1,
      "expected": "atl:confluence"
    }
