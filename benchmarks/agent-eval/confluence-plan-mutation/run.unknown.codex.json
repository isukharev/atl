  "model": "gpt-5.6-luna",
  "reasoning": "high",
  "prompt_file": "prompt.unknown.codex.md",
  "response_schema_file": "response-schema.json",
  "qualitative_rubric_file": "rubric.v1.json",
  "workspace_template": "workspace",
  "fixture_file": "fixture.unknown.json",
  "repetitions": 3,
  "timeout_seconds": 600,
  "max_estimated_cost_microusd": 5000000,
  "pricing": {"input_microusd_per_million_tokens": 1000000, "output_microusd_per_million_tokens": 6000000},
  "allowed_tools": ["Bash(atl *)", "Skill", "Read"],
  "allowed_cli_commands": [
    {"name": "conf_plan_create", "command": ["conf", "plan", "create"], "positionals": [{"values": ["mirror"]}], "flags": [{"name": "--out", "values": ["plan.json"], "required": true}], "max_invocations": 1},
    {"name": "conf_plan_preview", "command": ["conf", "plan", "preview"], "positionals": [{"values": ["plan.json"]}], "max_invocations": 1},
    {"name": "conf_plan_apply", "command": ["conf", "plan", "apply"], "positionals": [{"values": ["plan.json"]}], "flags": [{"name": "--confirm", "values": ["APPLY"], "required": true}, {"name": "--expected-proposal-hash", "value_format": "sha256", "required": true}], "max_invocations": 1}
  ],
  "allow_synthetic_writes": true,
  "checks": [
    {"name": "atl_outcome_expected", "kind": "atl_failures_equals", "expected": 1},
    {"name": "expected_version_correct", "kind": "json_equals", "pointer": "/expected_version", "expected": 7},
    {"name": "guard_clean", "kind": "guard_no_denials"},
    {"name": "http_exact", "kind": "http_methods_equal", "expected": {"GET": 3, "PUT": 1}},
    {"name": "mock_clean", "kind": "mock_no_unexpected"},
    {"name": "next_action_correct", "kind": "json_equals", "pointer": "/next_action", "expected": "reconcile_before_any_retry"},
    {"name": "outcome_correct", "kind": "json_equals", "pointer": "/outcome", "expected": "unknown"},
    {"name": "page_correct", "kind": "json_equals", "pointer": "/page_id", "expected": "7201"},
    {"name": "proposal_hash_correct", "kind": "json_equals_workspace_json", "pointer": "/proposal_hash", "expected": {"path": "plan.json", "pointer": "/proposal_hash"}},
    {"name": "replayed_false", "kind": "json_equals", "pointer": "/replayed", "expected": false},
    {"name": "used_atl", "kind": "atl_invocations_min", "minimum": 1},
    {"name": "used_atl_thrice", "kind": "atl_invocations_max", "maximum": 3},
    {"name": "used_skill", "kind": "skill_invocations_min", "minimum": 1},
    {"name": "write_attempted_correct", "kind": "json_equals", "pointer": "/write_attempted", "expected": true}
  ]
}
