    {"name":"proposal_hash_correct","kind":"json_equals_workspace_json","pointer":"/proposal_hash","expected":{"path":"plan.json","pointer":"/proposal_hash"}},
    {"name":"replayed_false","kind":"json_equals","pointer":"/replayed","expected":false},
