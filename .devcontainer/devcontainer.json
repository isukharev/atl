{
  "name": "atl dev",
  "image": "mcr.microsoft.com/devcontainers/go:1.26-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "mounts": [
    "source=atl-claude-config,target=/home/vscode/.claude,type=volume",
    "source=atl-gh-config,target=/home/vscode/.config/gh,type=volume"
  ],

  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude"
  },

  "postCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "editorconfig.editorconfig",
        "Anthropic.claude-code"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint",
        "go.formatTool": "goimports",
        "editor.formatOnSave": true,
        "[go]": {
          "editor.defaultFormatter": "golang.go",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "gopls": {
          "ui.semanticTokens": true
        }
      }
    }
  },

  "remoteUser": "vscode"
}
