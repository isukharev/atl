# Live integration test config — opt-in, NEVER committed.
#
# These tests hit a REAL Confluence/Jira Data Center. They never run in CI and
# never run under `make test`; only `make integration` reads this file.
#
# Setup:
#   cp .env.integration.example .env.integration
#   # edit .env.integration with your DC URLs, PATs, and throwaway test objects
#   make integration
#
# .env.integration is gitignored — your real DC URL and tokens stay local and
# never reach the repository. Keep test objects disposable: the tests below are
# read-only, but point them at scratch pages/projects you own regardless.

# --- Backend URLs (must be https; never commit the real ones) ---
CONFLUENCE_URL=https://confluence.example.com
JIRA_URL=https://jira.example.com

# --- Personal Access Tokens (integration-only env names; gated by ATL_INTEGRATION) ---
TEST_CONFLUENCE_PAT=your-confluence-pat
TEST_JIRA_PAT=your-jira-pat

# --- Confluence test target: a disposable page you own ---
ATL_TEST_PAGE_ID=000000000

# --- Jira field-options test target ---
# Project key + a field that HAS allowed values (e.g. priority). Issue type is
# optional; leave it empty to scan every type in the project.
ATL_TEST_JIRA_PROJECT=ABC
ATL_TEST_JIRA_ISSUETYPE=
ATL_TEST_JIRA_FIELD=priority
